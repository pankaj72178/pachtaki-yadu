{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "*.html",
          "*.js",
          "*.css",
          "*.jpg",
          "*.png",
          "*.ico",
          "data/**"
        ]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "/server.js" }]
}
